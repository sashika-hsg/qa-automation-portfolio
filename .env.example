# =============================================================================
# Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to Git
# =============================================================================

# Environment name
ENV=dev

# -----------------------------------------------------------------------------
# Sauce Demo — https://www.saucedemo.com
# -----------------------------------------------------------------------------
SAUCE_DEMO_BASE_URL=https://www.saucedemo.com
SAUCE_DEMO_USERNAME=standard_user
SAUCE_DEMO_PASSWORD=secret_sauce

# -----------------------------------------------------------------------------
# The Internet — https://the-internet.herokuapp.com
# -----------------------------------------------------------------------------
THE_INTERNET_BASE_URL=https://the-internet.herokuapp.com

# -----------------------------------------------------------------------------
# Restful Booker — https://restful-booker.herokuapp.com
# -----------------------------------------------------------------------------
RESTFUL_BOOKER_BASE_URL=https://restful-booker.herokuapp.com

# -----------------------------------------------------------------------------
# ReqRes — https://reqres.in
# -----------------------------------------------------------------------------
REQRES_BASE_URL=https://reqres.in
REQRES_API_KEY=free_user_3F4WngrrVmlOZ19BosYFhQ3xuWw

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DB_PATH=./data/test.db

# -----------------------------------------------------------------------------
# AI Integration — Claude API
# Get your key from https://console.anthropic.com
# -----------------------------------------------------------------------------
AI_ENABLED=false
CLAUDE_API_KEY=your_claude_api_key_here

# -----------------------------------------------------------------------------
# AWS CloudWatch
# -----------------------------------------------------------------------------
AWS_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here