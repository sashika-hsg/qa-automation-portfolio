{
  "name": "qa-automation-portfolio",
  "version": "1.0.0",
  "description": ">Production-grade QA automation framework built with Playwright, Typescript,\r >BDD AI integratio, and full QA lifecycle documentation.",
  "homepage": "https://github.com/sashika-hsg/qa-automation-portfolio#readme",
  "bugs": {
    "url": "https://github.com/sashika-hsg/qa-automation-portfolio/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sashika-hsg/qa-automation-portfolio.git"
  },
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "prepare": "husky",
    "test:ui": "playwright test tests/ui --reporter=html,allure-playwright",
    "test:api": "playwright test tests/api/reqres tests/api/restfulBooker --reporter=html,allure-playwright",
    "test:graphql": "playwright test tests/api/graphql --reporter=html,allure-playwright",
    "test:db": "playwright test tests/db --reporter=html,allure-playwright",
    "test:accessibility": "playwright test tests/accessibility --reporter=html",
    "test:security": "playwright test tests/api/security --reporter=html",
    "test:smoke": "playwright test --grep @smoke --reporter=html,allure-playwright",
    "test:regression": "playwright test --grep @regression --reporter=html,allure-playwright",
    "test:all": "playwright test --reporter=html,allure-playwright",
    "test:newman": "newman run postman/collections/ReqRes.postman_collection.json -e postman/environments/dev.postman_environment.json --reporters cli,htmlextra --reporter-htmlextra-export reports/newman/report.html",
    "test:ui:bdd": "cucumber-js features/ui/**/*.feature --require step-definitions/ui/**/*.ts",
    "test:api:bdd": "cucumber-js features/api/**/*.feature --require step-definitions/api/**/*.ts",
    "db:seed": "ts-node src/db/seed/seed.ts",
    "report:allure:generate": "allure generate reports/allure-results --clean -o reports/allure-report",
    "report:allure:open": "allure open reports/allure-report",
    "report:allure": "npm run report:allure:generate && npm run report:allure:open",
    "lint": "eslint . --ext .ts --ignore-pattern node_modules/ --ignore-pattern dist/",
    "lint:fix": "eslint . --ext .ts --fix --ignore-pattern node_modules/ --ignore-pattern dist/",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "ai:generate-data": "ts-node src/ai/AiDataGenerator.ts",
    "ai:suggest-commit": "ts-node src/ai/AiCommitHelper.ts"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@cucumber/cucumber": "^12.9.0",
    "@cucumber/pretty-formatter": "^3.3.1",
    "@playwright/test": "^1.60.0",
    "@types/better-sqlite3": "^7.6.13",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "dotenv": "^17.4.2",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3"
  },
  "dependencies": {
    "@types/node": "^25.8.0",
    "ts-node": "^10.9.2"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
