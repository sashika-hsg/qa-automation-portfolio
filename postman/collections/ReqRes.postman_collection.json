    {
      "name": "Create User",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "//Status code check\r",
              "pm.test(\"Status code is 201\", function(){\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "//Respone time check\r",
              "pm.test(\"Response time is less than 2000ms\", function(){\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
              "});\r",
              "\r",
              "//Schema validation\r",
              "pm.test(\"Response has required fields\", function(){\r",
              "    const body = pm.response.json();\r",
              "    pm.expect(body).to.have.property(\"name\");\r",
              "    pm.expect(body).to.have.property(\"job\");\r",
              "    pm.expect(body).to.have.property(\"id\");\r",
              "    pm.expect(body).to.have.property(\"createdAt\");\r",
              "    pm.expect(body).to.have.property(\"_meta\");\r",
              "});\r",
              "\r",
              "//Filed value validation\r",
              "pm.test(\"Returned name and job matches request body\", function(){\r",
              "    const body = pm.response.json();\r",
              "    pm.expect(body.name.trim()).to.eql(pm.environment.get(\"user_name\"));\r",
              "    pm.expect(body.job.trim()).to.eql(pm.environment.get(\"user_job\"));\r",
              "});\r",
              "//Store the created uer ID\r",
              "pm.test(\"Store created ID\", function(){\r",
              "    const body = pm.response.json();\r",
              "    pm.environment.set(\"user_id\",body.id);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
