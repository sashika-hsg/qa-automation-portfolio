      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "\r",
              "//Statuscode check\r",
              "pm.test(\"Status code is 200\", function(){\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "//Reposne time check\r",
              "pm.test(\"Response time is less than 2000ms\", function(){\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);  \r",
              "});\r",
              "\r",
              "//Schema validation\r",
              "pm.test(\"Response has data, support and _meta fields\", function(){\r",
              "    const body = pm.response.json();\r",
              "    pm.expect(body).to.have.property(\"data\");\r",
              "    pm.expect(body).to.have.property(\"support\");\r",
              "    pm.expect(body).to.have.property(\"_meta\");\r",
              "});\r",
              "\r",
              "//User field validation\r",
              "pm.test(\"User has required fields\", function(){\r",
              "    const user = pm.response.json().data;\r",
              "    pm.expect(user).to.have.property(\"id\");\r",
              "    pm.expect(user).to.have.property(\"email\");\r",
              "    pm.expect(user).to.have.property(\"first_name\");\r",
              "    pm.expect(user).to.have.property(\"last_name\");\r",
              "});\r",
              "\r",
              "//User ID matches with the request user_id\r",
              "pm.test(\"Returned user ID matches request user ID\", function(){\r",
              "    const user = pm.response.json().data;\r",
              "    pm.expect(user.id).to.equal(pm.environment.get(\"user_id\"));\r",
              "});\r",
              "\r",
              "\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
