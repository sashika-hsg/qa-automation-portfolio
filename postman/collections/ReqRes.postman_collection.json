  "item": [
    {
      "name": "Get User List",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "//Status codecheck\r",
              "pm.test(\"Status code is 200\", function(){\r",
              " pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "//Response time check \r",
              "pm.test(\"Reponse time is less than 2000ms\",function(){\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
              "});\r",
              "\r",
              "//Schema validation\r",
              "pm.test(\"Response has page and data fields\",function(){\r",
              "    const body = pm.response.json();\r",
              "    pm.expect(body).to.have.property(\"page\");\r",
              "    pm.expect(body).to.have.property(\"data\");\r",
              "    pm.expect(Array.isArray(body.data)).to.be.true;\r",
              "    pm.expect(body.data.length).to.be.greaterThan(0);\r",
              "});\r",
              "\r",
              "//Data field validation\r",
              "pm.test(\"Each user has id, email, first_name and last_name\", function(){\r",
              "    const body = pm.response.json();\r",
              "    body.data.forEach(function(user){\r",
              "        pm.expect(user).to.have.property(\"id\");\r",
              "        pm.expect(user).to.have.property(\"email\");\r",
              "        pm.expect(user).to.have.property(\"first_name\");\r",
              "        pm.expect(user).to.have.property(\"last_name\");\r",
              "    });\r",
              "});\r",
              "//Store first user id in environment variable for later user\r",
              "pm.test(\"Store first user id\", function(){\r",
              "    const body = pm.response.json();\r",
              "    pm.environment.set(\"user_id\", body.data[0].id);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "x-api-key",
            "value": "{{api_key}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/users?page=1",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "users"
          ],
          "query": [
            {
              "key": "page",
              "value": "1"
            }
          ]
        }
      },
      "response": []
    },
