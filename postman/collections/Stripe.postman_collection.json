              "type": "text",
              "uuid": "2bc2021e-75f6-4234-ac76-377592ba1324"
            },
            {
              "key": "currency",
              "value": "{{specified_currency}}",
              "type": "text",
              "uuid": "95f56ad0-033b-4621-b0e7-38caccb40ab9"
            },
            {
              "key": "automatic_payment_methods[enabled]",
