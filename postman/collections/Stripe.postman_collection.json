  "item": [
    {
      "name": "Create Payment Intent",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "//test for the status code\r",
              "pm.test(\"status code must be 200\", function(){\r",
              "    pm.response.to.have.status(parseInt(pm.environment.get(\"success_status_code\")));\r",
              "});\r",
              "\r",
              "pm.test(\"Payment intent is created with correct status\", function(){\r",
              "    const body = pm.response.json();\r",
              "    pm.expect(body.status).to.eql(\"requires_payment_method\");\r",
              "    pm.expect(body.amount).to.eql(parseInt(pm.environment.get(\"specified_amount\")));\r",
              "    pm.expect(body.currency).to.eql(pm.environment.get(\"specified_currency\"));\r",
              "    pm.expect(body.livemode).to.be.false;\r",
              "});\r",
              "\r",
              "pm.test(\"Store payment intent\",function(){\r",
              "    const body = pm.response.json();\r",
              "    pm.environment.set(\"payment_intent_id\", body.id);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "basic",
          "basic": [
            {
              "key": "username",
              "value": "{{secret_key}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            {
              "key": "amount",
