    {
      "name": "Create Payment Intent Refund Flow",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "//test for the status code\r",
              "pm.test(\"status code must be 200\", function(){\r",
              "    pm.response.to.have.status(parseInt(pm.environment.get(\"success_status_code\")));\r",
              "});\r",
              "\r",
              "pm.test(\"Refund is created successfully\", function(){\r",
              "    const body =  pm.response.json();\r",
              "    pm.expect(body.object).to.eql(\"refund\");\r",
              "    pm.expect(body.status).to.eql(\"succeeded\");\r",
              "    pm.expect(body.amount).to.eql(parseInt(pm.environment.get(\"specified_amount\")));\r",
              "    pm.expect(body.currency).to.eql(pm.environment.get(\"specified_currency\"));\r",
              "});\r",
              "\r",
              "pm.test(\"Refund is linked to the correct charge\", function() {\r",
              "    const body = pm.response.json();\r",
              "    pm.expect(body.charge).to.be.eql(pm.environment.get(\"charge_id\"));\r",
              "});\r",
              "\r",
              "pm.test(\"Store refund ID\", function() {\r",
              "    const body = pm.response.json();\r",
              "    pm.environment.set(\"refund_id\", body.id);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
