    {
      "name": "Confirm Payment Intent",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function(){\r",
              "        pm.response.to.have.status(parseInt(pm.environment.get(\"success_status_code\")));\r",
              "});\r",
              "\r",
              "pm.test(\"Payment intent is confirmed\", function(){\r",
              "    const body = pm.response.json();\r",
              "    pm.expect(body.status).to.eql(\"succeeded\");\r",
              "    pm.expect(body.amount_received).to.eql(parseInt(pm.environment.get(\"specified_amount\")));\r",
              "    pm.expect(body.livemode).to.eql(false);\r",
              "});\r",
              "\r",
              "pm.test('Payment method is attached', function(){\r",
              "    const body = pm.response.json();\r",
              "    pm.expect(body.payment_method).to.not.eql(null);\r",
              "});\r",
              "\r",
              "pm.test(\"Store charge ID for refund\", function(){\r",
              "    const body = pm.response.json();\r",
              "    pm.environment.set(\"charge_id\", body.latest_charge);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "basic",
          "basic": [
            {
              "key": "username",
              "value": "{{secret_key}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            {
              "key": "payment_method",
              "value": "pm_card_visa",
              "type": "text",
              "uuid": "97c11f32-0222-4186-8e29-c20a8054e3fc"
            }
          ]
        },
        "url": {
          "raw": "{{base_url}}/v1/payment_intents/{{payment_intent_id}}/confirm",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "v1",
            "payment_intents",
            "{{payment_intent_id}}",
            "confirm"
          ]
        }
      },
      "response": []
