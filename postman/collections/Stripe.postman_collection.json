    {
      "name": "Confirm Payment Intent Decline",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 402\", function(){\r",
              "        pm.response.to.have.status(parseInt(pm.environment.get(\"payment_required_status_code\")));\r",
              "});\r",
              "\r",
              "pm.test(\"Payment is declined with card decline error\", function(){\r",
              "    const body = pm.response.json();\r",
              "    pm.expect(body.error.code).to.eql('card_declined');\r",
              "    pm.expect(body.error.type).to.eql(\"card_error\");\r",
              "\r",
              "});\r",
              "\r",
              "pm.test('Decline reason is documented', function(){\r",
              "    const body = pm.response.json();\r",
              "    pm.expect(body.error.message).to.be.a(\"string\");\r",
              "    pm.expect(body.error.message.length).to.be.greaterThan(0);\r",
              "});\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
