              "type": "text",
              "uuid": "88bd4ada-b6eb-4140-9bdd-ea48718e4f3b"
            },
            {
              "key": "automatic_payment_methods[allow_redirects]",
              "value": "never",
              "type": "text",
              "uuid": "142d5856-7cbc-43e8-9de7-90e8d8fc3c59"
            }
