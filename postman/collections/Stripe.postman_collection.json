    {
      "name": "Retrieve Payment Intent",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function(){\r",
              "        pm.response.to.have.status(parseInt(pm.environment.get(\"success_status_code\")));\r",
              "});\r",
              "\r",
              "pm.test(\"Retrieved payment intent matches created intent\", function(){\r",
              "    const body = pm.response.json();\r",
              "    pm.expect(body.id).to.eql(pm.environment.get(\"payment_intent_id\"));\r",
              "    pm.expect(body.status).to.eql(\"succeeded\");\r",
              "    pm.expect(body.amount).to.eql(parseInt(pm.environment.get(\"specified_amount\")));\r",
              "    pm.expect(body.currency).to.eql(pm.environment.get(\"specified_currency\"));\r",
              "    pm.expect(body.livemode).to.eql(false);\r",
              "    \r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
